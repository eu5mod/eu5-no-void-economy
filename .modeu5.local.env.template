# Copy this file to `.modeu5.local.env` and keep the real file uncommitted.
#
# Path to the vanilla EU5 `game/in_game/common` directory.
EU5_GAME_COMMON_DIR="<EU5_INSTALL_DIR>/game/in_game/common"

# Optional: US-09 source-output compensation percentage used by `tools/generate_all.sh`.
MODEU5_US09_BONUS_PERCENT=10 # example : 10 for 10%
MODEU5_US15_BONUS_PERCENT=0.015 # example : 1.5%
MODEU5_US16_CASSUS_BELLI_VALIDITY=12 # example : 12 for 12 years
